SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# If the deployment environment provides the newer Supabase secret-key bundle
# instead of a legacy service role key, set SUPABASE_SECRET_KEYS and omit
# SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SECRET_KEYS={"default":"your-server-only-secret-key"}

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=prodaja@mimgradnja.rs
BREVO_SENDER_NAME=M & M Gradnja
SALES_EMAIL=prodaja@mimgradnja.rs

# Server-only Cloudflare Turnstile verification settings for public forms.
# Existing Supabase secret name used by this project.
MIM_SECRET_KEY_CAPTCHA=your-cloudflare-turnstile-secret-key
# Alternative name accepted for compatibility.
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
TURNSTILE_ALLOWED_HOSTNAMES=mimgradnja.rs,www.mimgradnja.rs
